# Discord Bot Token
DISCORD_TOKEN=your_discord_token_here

# Target vanities to snipe (comma-separated)
TARGET_VANITIES=vanity1,vanity2,vanity3

# Check interval in milliseconds (default: 100ms for lightning speed)
# Options: 50ms (ultra-fast), 100ms (recommended), 500ms (conservative)
CHECK_INTERVAL=100

# Maximum retry attempts when claiming vanity
MAX_RETRIES=5

# Environment
NODE_ENV=production
